{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.ts", "**/*.test.ts", "**/*.spec.ts"],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/scripts/**/*.ts"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "lcov", "clover"],
  "verbose": true
}
