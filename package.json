{
  "name": "crawl-site",
  "version": "0.0.4",
  "changed": "2026.04.25, 15:04",
  "description": "A TypeScript-based website crawler and scanner with resume capability",
  "main": "src/crawl.ts",
  "keywords": [
    "crawler",
    "scraper",
    "sitemap",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^23.0.1",
    "robots-parser": "^3.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^21.1.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.10.6",
    "@types/xml2js": "^0.4.14",
    "jest": "^29.7.0",
    "oxlint": "^0.0.22",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist && (rimraf -g crawl-dest || true)",
    "scan": "tsx src/scripts/scan.ts",
    "scan-build": "node dist/scripts/scan.js",
    "start": "pnpm scan",
    "start-build": "pnpm build && pnpm scan-build",
    "dev": "tsx watch src/scripts/scan.ts",
    "report": "tsx src/scripts/report.ts",
    "cli-help": "tsx src/scripts/help.ts",
    "lint": "oxlint src",
    "lint-fix": "oxlint src --fix",
    "check-types": "tsc --pretty --noEmit",
    "format": "pretty-quick --write --cache .",
    "format-full": "prettier --write --cache . | grep -v -e cached -e unchanged || true",
    "format-check": "prettier --check --cache .",
    "check-all": "pnpm format && pnpm check-types && pnpm lint",
    "check-full": "pnpm format-full && pnpm check-types && pnpm lint-fix && pnpm test",
    "test": "jest",
    "test-watch": "jest --watch"
  }
}
